# מפתח API של Anthropic - נדרש כדי שתכונת "חברותא AI" תעבוד.
# ניתן ליצור מפתח בכתובת: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# אופציונלי - אם רוצים להשתמש במודל אחר (ברירת מחדל: claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# אופציונלי - פורט לשרת (ברירת מחדל: 5000)
# PORT=5000

# --- חשבונות משתמשים ותשלומים ---

# בסיס נתונים - ב-Railway, זה מוזרק אוטומטית כשמצרפים שירות PostgreSQL לפרויקט (אין צורך למלא ידנית)
# DATABASE_URL=

# סוד לחתימת טוקני התחברות (JWT) - חובה להגדיר בפרודקשן! כל מחרוזת אקראית וארוכה מספיקה.
# אפשר ליצור אחת עם: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Google OAuth - מ-https://console.cloud.google.com/apis/credentials (OAuth Client ID מסוג Web Application)
GOOGLE_CLIENT_ID=

# PayPal - מ-https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# ה-Plan ID של מנוי חודשי שיצרת ב-PayPal (Product + Billing Plan)
PAYPAL_PLAN_ID=
# sandbox לבדיקות, live לתשלומים אמיתיים
# PAYPAL_MODE=sandbox
